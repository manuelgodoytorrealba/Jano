generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum UserPlan {
  FREE
  PREMIUM
}

enum EntityType {
  ARTWORK
  ARTIST
  CONCEPT
  MOVEMENT
  PERIOD
  TEXT
  PLACE
}

enum EntityStatus {
  DRAFT
  IN_REVIEW
  PUBLISHED
}

enum ContentLevel {
  BASIC
  INTERMEDIATE
  ADVANCED
}

enum MediaKind {
  IMAGE
}

enum MediaRole {
  PRIMARY
}

enum SourceType {
  BOOK
  ARTICLE
  WEBSITE
  CATALOG
  PAPER
}

model Entity {
  id           String        @id @default(cuid())
  type         EntityType
  title        String
  slug         String        @unique
  summary      String?
  content      String?
  contentLevel ContentLevel?
  status       EntityStatus  @default(DRAFT)

  startYear Int?
  endYear   Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Graph
  outgoing Relation[] @relation("outgoing")
  incoming Relation[] @relation("incoming")

  // Media (1..n)
  mediaLinks EntityMedia[]

  // Sources
  sourceRefs SourceRef[]

  // Internal notes
  curatorNotes CuratorNote[]

  // Collaborators / contributors
  contributors Contributor[]

  // Saved by users
  savedBy SavedEntity[]

  // Collections
  collectionItems CollectionEntity[]

  // Type-specific details (1..1, optional)
  artwork ArtworkDetails?
  artist  ArtistDetails?
  concept ConceptDetails?
  period  PeriodDetails?
}

model Relation {
  id            String  @id @default(cuid())
  fromId        String
  toId          String
  type          String // "CREATED_BY", "REPRESENTS_CONCEPT", ...
  weight        Float?
  justification String?

  from Entity @relation("outgoing", fields: [fromId], references: [id])
  to   Entity @relation("incoming", fields: [toId], references: [id])

  @@index([fromId])
  @@index([toId])
  @@index([type])
}

model Media {
  id   String    @id @default(cuid())
  url  String
  kind MediaKind @default(IMAGE)

  alt     String?
  source  String? // where it comes from (page/museum/etc)
  photoBy String? // photographer
  license String? // license type

  createdAt DateTime @default(now())

  entities EntityMedia[]
}

model EntityMedia {
  id       String    @id @default(cuid())
  entityId String
  mediaId  String
  role     MediaRole @default(PRIMARY)

  entity Entity @relation(fields: [entityId], references: [id])
  media  Media  @relation(fields: [mediaId], references: [id])

  @@index([entityId])
  @@index([mediaId])
}

model Source {
  id        String     @id @default(cuid())
  type      SourceType
  author    String?
  title     String
  publisher String?
  year      Int?
  url       String?

  createdAt DateTime @default(now())

  refs SourceRef[]
}

model SourceRef {
  id       String @id @default(cuid())
  entityId String
  sourceId String

  page  String?
  quote String?
  note  String?

  entity Entity @relation(fields: [entityId], references: [id])
  source Source @relation(fields: [sourceId], references: [id])

  @@index([entityId])
  @@index([sourceId])
}

model CuratorNote {
  id        String   @id @default(cuid())
  entityId  String
  body      String
  createdAt DateTime @default(now())

  entity Entity @relation(fields: [entityId], references: [id])

  @@index([entityId])
}

model Contributor {
  id       String @id @default(cuid())
  entityId String

  name String
  role String // curator | advisor | restorer | composer | ...
  note String?

  entity Entity @relation(fields: [entityId], references: [id])

  @@index([entityId])
}

model ArtworkDetails {
  entityId     String  @id
  authorNation String?

  technique  String?
  materials  String?
  dimensions String?

  location   String? // museum/gallery/current location
  collection String?
  state      String? // restored, destroyed, unfinished...

  entity Entity @relation(fields: [entityId], references: [id])
}

model ArtistDetails {
  entityId String @id

  country   String?
  city      String?
  birthYear Int?
  deathYear Int?

  disciplines String? // simple string list for now
  bioShort    String?
  links       String? // simple string list for now

  entity Entity @relation(fields: [entityId], references: [id])
}

model ConceptDetails {
  entityId   String  @id
  definition String?

  entity Entity @relation(fields: [entityId], references: [id])
}

model PeriodDetails {
  entityId   String  @id
  definition String?

  entity Entity @relation(fields: [entityId], references: [id])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         UserRole @default(USER)
  plan         UserPlan @default(FREE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  savedEntities SavedEntity[]
  collections   Collection[]
}

model SavedEntity {
  id        String   @id @default(cuid())
  userId    String
  entityId  String
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  entity Entity @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([userId, entityId])
  @@index([userId])
  @@index([entityId])
  @@index([createdAt])
}

model Collection {
  id          String  @id @default(cuid())
  userId      String
  name        String
  description String?
  isDefault   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  items CollectionEntity[]

  @@unique([userId, name])
  @@index([userId])
}

model CollectionEntity {
  id           String   @id @default(cuid())
  collectionId String
  entityId     String
  createdAt    DateTime @default(now())

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  entity     Entity     @relation(fields: [entityId], references: [id], onDelete: Cascade)

  @@unique([collectionId, entityId])
  @@index([collectionId])
  @@index([entityId])
  @@index([createdAt])
}
