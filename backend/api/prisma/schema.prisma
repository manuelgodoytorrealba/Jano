generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  
}

enum EntityType {
  ARTWORK
  ARTIST
  MOVEMENT
  CONCEPT
  TEXT
}

model Entity {
  id          String     @id @default(cuid())
  type        EntityType
  title       String
  slug        String     @unique
  summary     String?
  content     String?    // markdown/html para textos críticos
  startYear   Int?       // límite temporal (inicio)
  endYear     Int?       // límite temporal (fin)
  metadata    Json?      // técnica, medidas, museo, etc.
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  outgoing    Relation[] @relation("outgoing")
  incoming    Relation[] @relation("incoming")
}

model Relation {
  id        String  @id @default(cuid())
  fromId    String
  toId      String
  type      String  // "CREATED_BY", "EXPLORES", "BELONGS_TO", etc.
  weight    Float?  // opcional: fuerza de relación
  note      String? // por qué está conectada

  from      Entity  @relation("outgoing", fields: [fromId], references: [id])
  to        Entity  @relation("incoming", fields: [toId], references: [id])

  @@index([fromId])
  @@index([toId])
  @@index([type])
}